# Example environment variables for production-llm-platform.
# Copy to .env (gitignored) and fill in actual values when needed.
# Referenced by .mcp.json and any code that needs secrets.

# GitHub (optional MCP server, redundant with gh CLI)
# Fine-grained PAT with read scopes for sriteja28 repos
GITHUB_TOKEN=

# Hugging Face (model artifacts, dataset access)
# Read-only token from https://huggingface.co/settings/tokens
HF_TOKEN=

# Postgres / pgvector (M5+, only if pgvector chosen as vector DB)
PGVECTOR_URL=

# Sentry (M8+, observability)
SENTRY_TOKEN=

# Slack (community lurking, read-only — channels:history, groups:history,
# im:history, mpim:history, users:read scopes only; NO write scopes)
SLACK_READ_TOKEN=

# Modal (cloud GPU sessions; usually configured via `modal token new`,
# not env var, but listed here for completeness)
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# Anthropic API (if directly invoking Claude API outside Claude Code)
# ANTHROPIC_API_KEY=
